{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/config.js", "/*.{css,js,png,jpg,svg,ico,woff,woff2}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "geolocation=(), microphone=(), camera=()"
  }
}
