#!/usr/bin/env bash
set -euo pipefail

BASELINE=".secrets.baseline"

if ! command -v detect-secrets >/dev/null 2>&1; then
  echo "detect-secrets not found. Install with: pip install detect-secrets" >&2
  exit 1
fi

if [ ! -f "$BASELINE" ]; then
  echo "Missing $BASELINE. Generate it with: detect-secrets scan > $BASELINE" >&2
  exit 1
fi

detect-secrets-hook --baseline "$BASELINE"
